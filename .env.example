# ── Agents Gateway Environment Configuration ──
# Copy to .env and adjust for your deployment.
# All AGW_ prefixed vars map to GatewayConfig fields via AGW_<section>__<field>.

# ── Auth ──
# Valid modes: dev-none, internal-only, cloudflare-access
AGW_AUTH__MODE=dev-none

# cloudflare-access mode (required in production with that mode):
# AGW_AUTH__MODE=cloudflare-access
# AGW_AUTH__CLOUDFLARE_TEAM_DOMAIN=<team>.cloudflareaccess.com
# AGW_AUTH__CLOUDFLARE_AUD=<application-audience-tag>
# AGW_AUTH__PUBLIC_BASE_URL=https://agents.example.com

# internal-only mode:
# AGW_AUTH__MODE=internal-only
# AGW_AUTH__INTERNAL_SECRET=<strong-random-secret>

# Unsafe private-IP bypass (off by default; only for dev):
# AGW_AUTH__ALLOW_UNSAFE_PRIVATE_IP_BYPASS=false
AGW_AUTH__JWT_LEEWAY_SECONDS=30

# ── Runtime ──
# Allow unsandboxed ProcessRuntime (off by default in production):
AGW_RUNTIME__ALLOW_PROCESS=false

# Docker sandbox limits (only used by docker runtime type):
AGW_RUNTIME__DOCKER_MEMORY=512m
AGW_RUNTIME__DOCKER_CPUS=1.0
AGW_RUNTIME__DOCKER_PIDS_LIMIT=128
AGW_RUNTIME__DOCKER_TMPFS_SIZE=64m

# Enable Docker network access (off by default; requires explicit manifest permission):
AGW_RUNTIME__DOCKER_NETWORK=false

# Task timeout in seconds for Docker/Process runtimes:
AGW_RUNTIME__TASK_TIMEOUT_SECONDS=300

# ── Service ──
AGW_SERVICE__HOST=0.0.0.0
AGW_SERVICE__PORT=8092
AGW_SERVICE__MCP_PATH=/mcp

# Rate limiting:
AGW_SERVICE__RATE_LIMITING__ENABLED=true
AGW_SERVICE__RATE_LIMITING__REQUESTS_PER_MINUTE=120

# ── Agents ──
AGW_AGENTS__DIR=./agents

# ── Storage ──
AGW_STORAGE__SQLITE_PATH=./data/agents-gateway.db
AGW_STORAGE__ARTIFACTS_DIR=./data/artifacts

# ── Observability ──
AGW_OBSERVABILITY__LOG_LEVEL=INFO
AGW_OBSERVABILITY__LOG_FORMAT=json
AGW_OBSERVABILITY__METRICS_ENABLED=true

# ── Environment ──
# dev | production. In production, dev-none auth mode is refused at boot.
AGW_ENV=dev